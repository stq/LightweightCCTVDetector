# ── Cameras ─────────────────────────────────────────────────────────────────────
# Root folder that contains one subfolder per camera.
# Camera name = subfolder name.  Log files are also written here.
#
# Example layout:
#   C:\cameras\
#     FrontDoor\   ← camera "FrontDoor"
#     Backyard\    ← camera "Backyard"
CAMERAS_ROOT=C:\cameras

# ── Email ───────────────────────────────────────────────────────────────────────
# IMPORTANT: Use an App Password, not your real account password.
# Yandex: https://id.yandex.ru/security/app-passwords  (port 465, smtp.yandex.ru)
# Gmail:  https://myaccount.google.com/apppasswords    (port 587, smtp.gmail.com)
EMAIL_ENABLED=true
EMAIL_FROM=your.camera@yandex.ru
EMAIL_TO=recipient@gmail.com
EMAIL_SMTP_HOST=smtp.yandex.ru
EMAIL_SMTP_PORT=465
EMAIL_USER=your.camera@yandex.ru
EMAIL_PASS=xxxxxxxxxxxx

# ── Telegram (private channel) ──────────────────────────────────────────────────
# Create a bot via @BotFather → get token.
# Get chat ID: add @userinfobot to the channel, or check the URL in Telegram Web.
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-1001234567890

# ── Telegram (optional public channel) ──────────────────────────────────────────
# A second bot that forwards alerts from selected cameras to a public group.
# PUBLIC_CAMERAS is a comma-separated list of camera folder names.
# Alerts from those cameras are sent to BOTH the private and public channels.
#PUBLIC_TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
#PUBLIC_TELEGRAM_CHAT_ID=-1009876543210
#PUBLIC_CAMERAS=FrontDoor,Backyard
