# ── Cameras (up to 8) ──────────────────────────────────────────────────────────
# At least CAMERA_1_FOLDER is required.
# CAMERA_N_NAME is optional (shown in alert subject/body).
CAMERA_1_FOLDER=C:\camera\ftp
CAMERA_1_NAME=Front Door
#CAMERA_2_FOLDER=C:\camera2\ftp
#CAMERA_2_NAME=Backyard
#CAMERA_3_FOLDER=C:\camera3\ftp
#CAMERA_3_NAME=Garage
#CAMERA_4_FOLDER=C:\camera4\ftp
#CAMERA_4_NAME=Camera 4
#CAMERA_5_FOLDER=C:\camera5\ftp
#CAMERA_5_NAME=Camera 5
#CAMERA_6_FOLDER=C:\camera6\ftp
#CAMERA_6_NAME=Camera 6
#CAMERA_7_FOLDER=C:\camera7\ftp
#CAMERA_7_NAME=Camera 7
#CAMERA_8_FOLDER=C:\camera8\ftp
#CAMERA_8_NAME=Camera 8

# Log folder (optional, defaults to CAMERA_1_FOLDER)
#LOG_FOLDER=C:\detector2\logs

# ── Email ───────────────────────────────────────────────────────────────────────
# IMPORTANT: Use an App Password, not your real account password.
# Yandex: https://id.yandex.ru/security/app-passwords  (port 465, smtp.yandex.ru)
# Gmail:  https://myaccount.google.com/apppasswords    (port 587, smtp.gmail.com)
EMAIL_ENABLED=true
EMAIL_FROM=your.camera@yandex.ru
EMAIL_TO=recipient@gmail.com
EMAIL_SMTP_HOST=smtp.yandex.ru
EMAIL_SMTP_PORT=465
EMAIL_USER=your.camera@yandex.ru
EMAIL_PASS=xxxxxxxxxxxx

# ── Telegram ────────────────────────────────────────────────────────────────────
# Create bot via @BotFather → get token.
# Get chat ID: add @userinfobot to the channel or check the URL in Telegram Web.
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-1001234567890
